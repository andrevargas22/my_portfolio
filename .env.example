# Environment Variables for Local Development

# Mapbox token for the travel map
MAPBOX_ACCESS_TOKEN=<mapbox_token_here>

# MNIST API endpoint
MNIST_ENDPOINT=<mnist_endpoint_here>

# GitHub App (Repository Dispatch)
GITHUB_APP_ID=<github_app_id_here>
GITHUB_APP_INSTALLATION_ID=<github_app_installation_id_here>

# Aliases for compatibility with WebSub code
GRENALBOT_ID=<github_app_id_here>
GRENALBOT_INSTALLATION_ID=<github_app_installation_id_here>

# Private key PEM multiline
GITHUB_APP_PRIVATE_KEY=<private_key_here>
GRENALBOT_PRIVATE_KEY=<private_key_here>

# HMAC secret to validate WebSub
WEBHOOK_HMAC_SECRET=<webhook_hmac_secret_here>

# YouTube Data API v3 key (for video availability checks)
YOUTUBE_API_KEY=<youtube_api_key_here>

# Google Cloud Storage bucket name (for audio uploads)
GCS_BUCKET_NAME=<gcs_bucket_name_here>

# YouTube cookies (base64-encoded Netscape format)
YOUTUBE_COOKIES_B64=<base64_encoded_cookies_here>

# Telegram bot for notifications (optional)
TELEGRAM_BOT_TOKEN=<telegram_bot_token_here>
TELEGRAM_CHAT_ID=<telegram_chat_id_here>
